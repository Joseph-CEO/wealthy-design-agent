# ──────────────────────────────────────────────
# Nairobi Designer Agent — Environment Variables
# ──────────────────────────────────────────────

# FastAPI
APP_NAME="Nairobi Designer Agent"
SECRET_KEY=change-this-to-a-random-secret-string
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./designer_agent.db

# ──────────────────────────────────────────────
# AI & NLP
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# Client Discovery (Apify)
# ──────────────────────────────────────────────
APIFY_API_KEY=apify_...
SCAN_INTERVAL_HOURS=6
LEAD_SCORE_THRESHOLD=70

# ──────────────────────────────────────────────
# Email Outreach (SendGrid)
# ──────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDER_EMAIL=yourname@example.com
SENDER_NAME="Your Name — Graphic Designer"

# ──────────────────────────────────────────────
# Stripe (Global Payments)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────
# M-Pesa (Kenya Payments)
# ──────────────────────────────────────────────
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...
MPESA_SHORTCODE=174379
MPESA_PASSKEY=...
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-backend.onrender.com/api/v1/webhooks/mpesa

# ──────────────────────────────────────────────
# Admin Dashboard
# ──────────────────────────────────────────────
# Set a token to password-protect admin endpoints. Leave empty for open access (dev only).
ADMIN_TOKEN=change-me-to-a-secret

# ──────────────────────────────────────────────
# Frontend URL (for CORS)
# ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Google Ads / Keyword Planner (SEO enrichment)
# ──────────────────────────────────────────────
# See https://developers.google.com/google-ads/api/docs/get-started
# Required to fetch real search volume for SEO keyword scoring.
# The app works without these (falls back to location-based scoring).
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
GOOGLE_ADS_REFRESH_TOKEN=...
GOOGLE_ADS_CUSTOMER_ID=...
# Optional: only if using a manager account
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=...

# ──────────────────────────────────────────────
# SEO (Programmatic Page Generation)
# ──────────────────────────────────────────────
SEO_INTERVAL_HOURS=168
SEO_BATCH_SIZE=50
