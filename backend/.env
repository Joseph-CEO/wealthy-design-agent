# ──────────────────────────────────────────────
# Nairobi Designer Agent — Environment Variables
# ──────────────────────────────────────────────

# FastAPI
APP_NAME="Nairobi Designer Agent"
SECRET_KEY=change-this-to-a-random-secret-string
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./designer_agent.db

# ──────────────────────────────────────────────
# AI & NLP
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# Client Discovery (Apify)
# ──────────────────────────────────────────────
APIFY_API_KEY=apify_...
SCAN_INTERVAL_HOURS=6
LEAD_SCORE_THRESHOLD=70

# ──────────────────────────────────────────────
# Email Outreach (SendGrid)
# ──────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDER_EMAIL=yourname@example.com
SENDER_NAME="Your Name — Graphic Designer"

# ──────────────────────────────────────────────
# Stripe (Global Payments)
# ──────────────────────────────────────────────
